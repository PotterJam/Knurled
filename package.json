{
  "name": "knurled",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "knurled": "cargo run -p knurled-cli --",
    "test": "cargo test --workspace",
    "test:workbench": "node --test workbench/test/*.mjs",
    "serve": "cargo run -p knurled-cli -- serve",
    "build:example": "cargo run -p knurled-cli -- build examples/gzclp-repo",
    "build:workbench": "bash workbench/scripts/build-wasm.sh",
    "deploy:workbench": "npx wrangler pages deploy workbench",
    "deploy:workbench:preview": "npx wrangler pages deploy workbench --branch preview"
  }
}
