// Copy this file to Secrets.xcconfig (gitignored) and fill in your values.
//
// Register a GitHub App at https://github.com/settings/apps/new with:
//   - Repository permissions: Contents (Read and write), Administration (Read and write)
//   - "Enable Device Flow" checked, Webhook unchecked, no callback URL needed
// Then paste its Client ID (starts with "Iv") and URL slug (the <name> in
// github.com/apps/<name>) here. The app reads them from the generated Info.plist
// keys `GitHubAppClientID` and `GitHubAppName`.
GITHUB_APP_CLIENT_ID = your_github_app_client_id
GITHUB_APP_NAME = your_github_app_name
